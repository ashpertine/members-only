<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Posts</title>
    <link rel="stylesheet" href="/posts.css">
  </head>
  <body>
    <div class="main-container">
      <% if(!noUser) { %>  
      <div class="buttons-container">
        <a href="/settings" class='settings'>
          <img src="/images/settings-icon.svg" alt="settings" width="25" height="20">
        </a> 
        <form method="POST" action="/auth/logout">
          <button type="submit" class="logout-button">Log Out</button>
        </form>
      </div>
      <% } %>
      <div class="posts-container">
        <% if(noPosts) { %>
          <p>No posts right now...</p>
        <% } else {%> 
          <% for(const post of allPosts) { %>
            <div class="posts-card">
              <h3><%= post.title %></h3> 
              <h4>By: <%= post.username %></h4>
              <p><%= post.content %></p> 
              <p><%= post.timestamp %></p> 
              <% if(isAdmin) {%>
                <form method="POST" action="/delete/<%= post.post_id %>">
                  <button type="submit" class="delete-button">
                    <img src="/images/delete-icon.svg" alt="delete"> 
                  </button> 
                </form>
              <% } %>
            </div>
          <% } %>
        <% } %>
      </div>
      <div class="interactive-container">
        <% if(noUser) { %>
          <a href="/auth/login" class="login-link">Log in to create posts</a>
        <% } else { %> 
          <div class="send-post-container">
            <button command="show-modal" commandfor="newPostDialog" class="post-dialog-button">New Post</button>
          </div>
          <dialog id="newPostDialog">
            <form method="POST" action="/new/post" class="post-form">
              <% if(postInputErrors.length > 0 ) {%>
                <p>Error: <%= postInputErrors[0].msg %></p>
              <% } %>
              <label for="title">Post Title: </label>
              <input type="text" name="title" id="title">
              <br>
              <label for="content">Content: </label>
              <br>
              <textarea rows="20" name="content" id="content"></textarea>
              <br>
              <div class="post-form-actions">  
                <button type="submit">Send</button>
                <button type="button" commandfor="newPostDialog" command="close">Cancel</button>
              </div>
            </form>
          </dialog>
        <% } %>
      </div>
    </div>
  </body>
</html>
<script>
  <% if(postInputErrors.length > 0) { %>
    document.getElementById('newPostDialog').showModal();
  <% } %>
</script>
